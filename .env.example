# ==============================================================================
# BLOCKCHAIN SERVICE CONFIGURATION (V2 - Method Specific)
# ==============================================================================

# ------------------------------------------------------------------------------
# 🟢 OPTION 1: POLYGON MAINNET (Active)
# ------------------------------------------------------------------------------
BLOCKCHAIN_RPC_URL=https://polygon-mainnet.infura.io/v3/YOUR_INFURA_KEY
BLOCKCHAIN_CHAIN_ID=137
BLOCKCHAIN_CONTRACT_ADDRESS=0xA4b62924be4dC1e61046804f59f3B8FA98Bc37e0
BLOCKCHAIN_EXPLORER_URL=https://polygonscan.com
BLOCKCHAIN_NETWORK_LABEL=Polygon Mainnet

# ------------------------------------------------------------------------------
# 🔵 OPTION 2: POLYGON AMOY (Testnet)
# ------------------------------------------------------------------------------
# BLOCKCHAIN_RPC_URL=https://rpc-amoy.polygon.technology
# BLOCKCHAIN_CHAIN_ID=80002
# BLOCKCHAIN_CONTRACT_ADDRESS=0xYourAmoyContractAddress
# BLOCKCHAIN_EXPLORER_URL=https://amoy.polygonscan.com
# BLOCKCHAIN_NETWORK_LABEL=Polygon Amoy

# ------------------------------------------------------------------------------
# 🟡 OPTION 3: ETHEREUM SEPOLIA (Testnet)
# ------------------------------------------------------------------------------
# BLOCKCHAIN_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
# BLOCKCHAIN_CHAIN_ID=11155111
# BLOCKCHAIN_CONTRACT_ADDRESS=0x5C5F6CE61647600bB8c04F59c0F2B493EBE78DDF
# BLOCKCHAIN_EXPLORER_URL=https://sepolia.etherscan.io
# BLOCKCHAIN_NETWORK_LABEL=Ethereum Sepolia

# ------------------------------------------------------------------------------
# GENERAL CONFIGURATION
# ------------------------------------------------------------------------------
PORT=4000
NODE_ENV=production
LOG_LEVEL=info

# Gas Configuration
BLOCKCHAIN_GAS_LIMIT=300000
BLOCKCHAIN_MAX_GAS_PRICE=50000000000

# ------------------------------------------------------------------------------
# 🔐 SECURITY: PRIVATE KEYS & API KEYS
# ------------------------------------------------------------------------------
# Wallet that will pay for gas and sign transactions
PRIVATE_KEY=your_private_key_here

# API Key for contract verification (Etherscan/Polygonscan)
ETHERSCAN_API_KEY=your_etherscan_api_key_here
