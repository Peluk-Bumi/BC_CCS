# ------------------------------------------------------------------------------
# 🔵 OPTION 3: HARDHAT LOCAL / FORK (Testing)
# ------------------------------------------------------------------------------
# BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
# BLOCKCHAIN_CHAIN_ID=31337
# BLOCKCHAIN_CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
# BLOCKCHAIN_EXPLORER_URL=http://localhost:8545
# BLOCKCHAIN_NETWORK_LABEL=Hardhat Local
# BLOCKCHAIN_FALLBACK_RPC_URLS=

# ------------------------------------------------------------------------------
# GENERAL CONFIGURATION
# ------------------------------------------------------------------------------
PORT=4000
NODE_ENV=production
LOG_LEVEL=info

# Gas Configuration
BLOCKCHAIN_GAS_LIMIT=300000
BLOCKCHAIN_MAX_GAS_PRICE=50000000000

# ------------------------------------------------------------------------------
# 🔐 SECURITY: PRIVATE KEYS & API KEYS
# ------------------------------------------------------------------------------
# Wallet that will pay for gas and sign transactions
PRIVATE_KEY=your_private_key_here

# API Key for contract verification (Etherscan/Polygonscan)
ETHERSCAN_API_KEY=your_etherscan_api_key_here
