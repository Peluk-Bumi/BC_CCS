# Blockchain Configuration (Backend)
BLOCKCHAIN_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID
BLOCKCHAIN_CHAIN_ID=11155111
BLOCKCHAIN_CONTRACT_ADDRESS=0xYOUR_CONTRACT_ADDRESS_HERE
BLOCKCHAIN_EXPLORER_URL=https://sepolia.etherscan.io
BLOCKCHAIN_NETWORK_LABEL=Sepolia Testnet

# Fallback RPC URLs (comma-separated, optional)
BLOCKCHAIN_FALLBACK_RPC_URLS=https://ethereum-sepolia-rpc.publicnode.com,https://sepolia-rpc.publicnode.com,https://rpc.sepolia.org

# Gas Configuration (optional)
BLOCKCHAIN_GAS_LIMIT=300000
BLOCKCHAIN_MAX_GAS_PRICE=50000000000

# Server Configuration
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# Security: Private Keys (Backend Only)
PRIVATE_KEY=your_private_key_here

# DEPRECATED: Will be removed in v2.0
# RPC_URL (use BLOCKCHAIN_RPC_URL)
# CONTRACT_ADDRESS (use BLOCKCHAIN_CONTRACT_ADDRESS)
